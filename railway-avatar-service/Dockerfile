# ============================================================
# Railway Avatar Service — EchoMimicV2 GPU Worker
# ============================================================
# Generates half-body talking avatar video from:
#   - A single reference photo (headshot)
#   - An audio file (voice, generated by ElevenLabs TTS)
#
# Uses EchoMimicV2 (Ant Group, CVPR 2025) for:
#   - Audio-driven lip sync
#   - Natural head movement
#   - Hand gesture generation
#   - Half-body animation
#
# Requires: NVIDIA GPU (A10G 24GB minimum, A100 80GB recommended)
# ============================================================

FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV TORCH_HOME=/app/models

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev python3-pip \
    git git-lfs wget curl \
    ffmpeg libsm6 libxext6 libgl1-mesa-glx \
    libglib2.0-0 libxrender1 \
    && rm -rf /var/lib/apt/lists/*

# Make python3.11 the default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

WORKDIR /app

# Install Python dependencies first (cached layer)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && pip install --no-cache-dir -r requirements.txt

# Clone EchoMimicV2 repository
RUN git clone https://github.com/antgroup/echomimic_v2.git /app/echomimic_v2 \
    && cd /app/echomimic_v2 \
    && pip install --no-cache-dir -e .

# Download pretrained models (this is a large download, ~10-15GB)
# Models are cached in the Docker image so they don't re-download on every deploy
RUN cd /app/echomimic_v2 \
    && python -c "from huggingface_hub import snapshot_download; snapshot_download('BadToBest/EchoMimicV2', local_dir='./pretrained_weights')" \
    || echo "Model download will happen at runtime if not cached"

# Copy our server code
COPY server.py .
COPY utils.py .

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:${PORT:-8080}/health || exit 1

EXPOSE ${PORT:-8080}

CMD ["python", "server.py"]
